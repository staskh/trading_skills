# Copy to .env and fill in values. The .env file is loaded automatically
# (via python-dotenv) by tests and by the ib-* skill scripts.

# Interactive Brokers connection port. Default when --port is not passed on an
# ib-* skill. Precedence: --port flag > IB_PORT > built-in default (7497 paper).
# Use 4001/4002 for the IB Gateway container (live/paper), 7496/7497 for TWS.
IB_PORT=

# Massive API key — enables the whale-hunting integration tests and skills.
MASSIVE_API_KEY=

# Financial Modeling Prep API key.
FMP_API_KEY=

# Langfuse tracing (optional).
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
